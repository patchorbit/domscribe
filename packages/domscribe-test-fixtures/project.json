{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "domscribe-test-fixtures",
  "projectType": "library",
  "root": "packages/domscribe-test-fixtures",
  "sourceRoot": "packages/domscribe-test-fixtures/src",
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "eslintConfig": "eslint.config.mjs",
        "lintFilePatterns": [
          "packages/domscribe-test-fixtures/**/*.ts",
          "packages/domscribe-test-fixtures/**/*.tsx"
        ]
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": [
        "{projectRoot}/test-output"
      ],
      "options": {
        "config": "packages/domscribe-test-fixtures/vite.config.ts"
      },
      "configurations": {
        "watch": {
          "watch": true
        }
      }
    },
    "build": {
      "executor": "nx:noop"
    },
    "typecheck": {
      "executor": "nx:noop"
    },
    "watch-deps": {
      "executor": "nx:noop"
    },
    "build-deps": {
      "executor": "nx:noop"
    }
  },
  "tags": [
    "type:test"
  ]
}