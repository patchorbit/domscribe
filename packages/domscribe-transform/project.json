{
  "name": "domscribe-transform",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/domscribe-transform/src",
  "tags": ["scope:build", "type:lib", "type:test"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{workspaceRoot}/dist/packages/domscribe-transform"],
      "options": {
        "rootDir": "packages/domscribe-transform/src",
        "outputPath": "dist/packages/domscribe-transform",
        "main": "packages/domscribe-transform/src/index.ts",
        "tsConfig": "packages/domscribe-transform/tsconfig.lib.json",
        "generatePackageJson": true,
        "generateExportsField": true,
        "assets": ["packages/domscribe-transform/*.md"]
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "eslintConfig": "eslint.config.mjs",
        "lintFilePatterns": [
          "packages/domscribe-transform/**/*.ts",
          "packages/domscribe-transform/**/*.tsx"
        ]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{projectRoot}/test-output"],
      "options": {
        "config": "packages/domscribe-transform/vite.config.ts"
      }
    },
    "typecheck": {
      "executor": "nx:noop"
    },
    "watch-deps": {
      "executor": "nx:noop"
    },
    "build-deps": {
      "executor": "nx:noop"
    }
  }
}
