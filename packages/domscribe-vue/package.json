{
  "name": "@domscribe/vue",
  "version": "0.1.0",
  "description": "Vue adapter for Domscribe",
  "type": "module",
  "main": "src/index.ts",
  "publishConfig": {
    "access": "restricted"
  },
  "distExports": {
    "./vite": "./vite/index.js",
    "./webpack": "./webpack/index.js",
    "./auto-init": "./auto-init.js"
  },
  "dependencies": {
    "@domscribe/core": "workspace:*",
    "@domscribe/runtime": "workspace:*",
    "@domscribe/transform": "workspace:*"
  },
  "devDependencies": {
    "@types/webpack": "^5.28.5",
    "happy-dom": "^12.0.0",
    "vue": "^3.5.0",
    "webpack": "^5.102.0"
  },
  "peerDependencies": {
    "vue": ">=3.3.0",
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "webpack": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  }
}
